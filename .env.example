# OpenAI API（推奨・サーバー側のみ）
OPENAI_API_KEY=sk-proj-...

# 任意: OpenAIモデル（既定 gpt-4o）
# OPENAI_MODEL=gpt-4o

# Anthropic API（Claudeを使う場合）
# ANTHROPIC_API_KEY=sk-ant-api03-...

# 任意: 明示的にプロバイダを指定（openai / anthropic）
# AI_PROVIDER=openai

# 任意: CORS（本番ドメインをカンマ区切り）
# CORS_ORIGIN=https://your-app.example.com

# 任意: ポート（ローカル開発、既定 8787）
# PORT=8787
